{
  "name": "md-go-validator-website",
  "version": "1.0.0",
  "private": true,
  "description": "Website and documentation for md-go-validator — validate code blocks in Markdown and MDX documentation",
  "keywords": [
    "astro",
    "documentation",
    "go",
    "golang",
    "markdown",
    "md-go-validator",
    "mdx",
    "starlight",
    "static-analysis",
    "validation"
  ],
  "homepage": "https://md-go-validator.lars.software",
  "bugs": "https://github.com/LarsArtmann/md-go-validator/issues",
  "license": "MIT",
  "author": "LarsArtmann <lars@larsartmann.com> (https://larsartmann.com/)",
  "repository": {
    "type": "git",
    "url": "https://github.com/LarsArtmann/md-go-validator.git",
    "directory": "website"
  },
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && node scripts/fix-csp.mjs",
    "preview": "astro preview",
    "typecheck": "astro check",
    "clean": "rm -rf dist .astro node_modules/.cache",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/starlight": "^0.41.1",
    "@tailwindcss/vite": "^4.3.1",
    "astro": "^7.0.3",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "html-validate": "^11.5.3",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "brace-expansion": "5.0.6",
    "devalue": "5.8.1",
    "yaml": "2.8.3"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
