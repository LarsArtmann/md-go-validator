---
import { comparisons } from '../data/sections';
import SectionHeader from './SectionHeader.astro';
---

<SectionHeader title="Why md-go-validator?" subtitle="Purpose-built for documentation validation. Not a generic linter." />

<div class="grid gap-4 sm:grid-cols-3">
  {comparisons.map((item) => (
    <div class={`p-6 rounded-xl border bg-bg-card text-center ${item.accent ? 'border-accent bg-accent-dim' : 'border-border'}`}>
      <div class="font-semibold text-text-primary mb-2 text-base">{item.variant}</div>
      {item.pros.map((pro) => (
        <div class="text-[0.8125rem] text-text-muted py-1"><span class="text-success" aria-hidden="true">&#x2713;</span> {pro}</div>
      ))}
      {item.cons.map((con) => (
        <div class="text-[0.8125rem] text-text-muted py-1"><span class="text-text-muted" aria-hidden="true">&#x2717;</span> {con}</div>
      ))}
    </div>
  ))}
</div>
