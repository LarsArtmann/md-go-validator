---
export interface Props {
  width?: number;
  height?: number;
  class?: string;
}

const { width = 28, height = 28, class: className } = Astro.props;
---

<svg class={className} width={width} height={height} viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="md-go-validator logo">
  <rect width="28" height="28" rx="6" class="fill-[var(--color-accent)]" />
  <path d="M8 14.5l3.5 3.5L20 9.5" class="fill-[var(--color-bg-primary)]" stroke="var(--color-bg-primary, #0a0908)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="none" />
</svg>
